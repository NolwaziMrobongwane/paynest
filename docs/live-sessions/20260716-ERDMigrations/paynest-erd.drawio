        <!-- Payments swimlane -->
        <mxCell id="payments-group" value="Payments (Capstone 4–5) — what Capstone 4 migrates to H2" style="swimlane;startSize=28;fillColor=#E3F2FD;strokeColor=#42A5F5;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="680" height="520" as="geometry" />
        </mxCell>

        <mxCell id="transaction_records" value="&lt;b&gt;transaction_records&lt;/b&gt;&lt;hr&gt;PK id : VARCHAR&lt;br&gt;UQ idempotency_key : VARCHAR&lt;br&gt;amount : DOUBLE&lt;br&gt;bank : VARCHAR&lt;br&gt;transaction_timestamp : TIMESTAMP&lt;br&gt;status : VARCHAR&lt;br&gt;created_at : TIMESTAMP&lt;br&gt;updated_at : TIMESTAMP&lt;br&gt;routing_summary : VARCHAR&lt;br&gt;assessed_risk : VARCHAR&lt;br&gt;monitoring_flag : BOOLEAN&lt;br&gt;ai_assessment_summary : CLOB&lt;br&gt;&lt;i&gt;← TransactionRecord + Transaction&lt;/i&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;rounded=0;shadow=0;comic=0;labelBackgroundColor=none;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#1565C0;spacingLeft=4;" vertex="1" parent="payments-group">
