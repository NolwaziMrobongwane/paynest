        <!-- Title / disclaimer -->
        <mxCell id="title" value="&lt;b&gt;PayNest ERD — visualisation only&lt;/b&gt;&lt;br&gt;Not required for writing migrations (Step 2). Write SQL from Java domain classes." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="720" height="50" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="&lt;b&gt;Legend (beginner)&lt;/b&gt;&lt;br&gt;PK = Primary Key (identifies one row)&lt;br&gt;FK = Foreign Key (points to another table)&lt;br&gt;UQ = Unique (no duplicates)&lt;br&gt;Line end with crow&#39;s foot = &quot;many&quot;&lt;br&gt;Line end with single bar = &quot;one&quot;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1180" y="20" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- Commerce swimlane -->
        <mxCell id="commerce-group" value="Commerce (Capstone 1) — in-memory today; shown for reading practice" style="swimlane;startSize=28;fillColor=#E8F5E9;strokeColor=#66BB6A;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="700" height="520" as="geometry" />
        </mxCell>

        <mxCell id="customers" value="&lt;b&gt;customers&lt;/b&gt;&lt;hr&gt;PK id : INT&lt;br&gt;name : VARCHAR&lt;br&gt;email : VARCHAR&lt;br&gt;&lt;i&gt;← Customer.java&lt;/i&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;rounded=0;shadow=0;comic=0;labelBackgroundColor=none;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#2E7D32;spacingLeft=4;" vertex="1" parent="commerce-group">
