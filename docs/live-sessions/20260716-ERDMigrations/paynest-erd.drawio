          <mxGeometry x="380" y="90" width="260" height="160" as="geometry" />
        </mxCell>

        <mxCell id="enum-note" value="&lt;b&gt;Enums as text&lt;/b&gt;&lt;br&gt;status: PENDING | ROUTED |&lt;br&gt;COMPLETED | FAILED&lt;br&gt;assessed_risk / resolved_risk:&lt;br&gt;LOW | MEDIUM | HIGH" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#FFF8E1;strokeColor=#FFB300;fontSize=10;" vertex="1" parent="payments-group">
          <mxGeometry x="40" y="340" width="280" height="100" as="geometry" />
