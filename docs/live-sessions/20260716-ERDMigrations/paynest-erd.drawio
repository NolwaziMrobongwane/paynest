        <mxCell id="products" value="&lt;b&gt;products&lt;/b&gt;&lt;hr&gt;PK id : INT&lt;br&gt;name : VARCHAR&lt;br&gt;price : DOUBLE&lt;br&gt;&lt;i&gt;← Product.java&lt;/i&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;rounded=0;shadow=0;comic=0;labelBackgroundColor=none;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#2E7D32;spacingLeft=4;" vertex="1" parent="commerce-group">
          <mxGeometry x="460" y="50" width="200" height="100" as="geometry" />
