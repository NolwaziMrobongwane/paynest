        <mxCell id="order_items" value="&lt;b&gt;order_items&lt;/b&gt;&lt;hr&gt;PK order_id : INT&lt;br&gt;PK product_id : INT&lt;br&gt;quantity : INT&lt;br&gt;&lt;i&gt;← OrderItem.java&lt;/i&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;rounded=0;shadow=0;comic=0;labelBackgroundColor=none;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#2E7D32;spacingLeft=4;" vertex="1" parent="commerce-group">
          <mxGeometry x="250" y="380" width="200" height="100" as="geometry" />
