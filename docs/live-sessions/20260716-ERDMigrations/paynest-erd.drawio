        <mxCell id="e-tx-ai" value="1:*" style="endArrow=ERmany;startArrow=ERone;html=1;rounded=0;strokeColor=#1565C0;fontSize=10;" edge="1" parent="payments-group" source="transaction_records" target="ai_decision_records">
