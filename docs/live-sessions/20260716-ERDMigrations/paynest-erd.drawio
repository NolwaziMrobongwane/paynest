        <!-- Commerce relationships -->
        <mxCell id="e-cust-ord" style="endArrow=ERmany;startArrow=ERone;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#2E7D32;" edge="1" parent="commerce-group" source="customers" target="orders">
